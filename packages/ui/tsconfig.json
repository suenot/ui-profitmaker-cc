{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": { "@/*": ["../../*"] }
  },
  "include": ["src", "tsup.config.ts", "../../components", "../../lib"],
  "exclude": ["node_modules", "dist", "../../components/**/*.stories.tsx"]
}
